datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Person {
  id            String   @id @default(cuid())
  name          String?
  email         String?
  phone         String?
  attributes    Json?    // e.g. { orderNumbers: ["123"] }
  notes         String?
  createdAt     DateTime @default(now())
  identities    ChannelIdentity[]
  conversations Conversation[]
}

model ChannelIdentity {
  id           String   @id @default(cuid())
  channel      Channel
  externalId   String   // phone number / IG user id / telegram user id
  displayName  String?
  person       Person   @relation(fields: [personId], references: [id])
  personId     String
  createdAt    DateTime @default(now())

  @@unique([channel, externalId])
}

model Conversation {
  id         String   @id @default(cuid())
  person     Person   @relation(fields: [personId], references: [id])
  personId   String
  channel    Channel
  status     ConversationStatus @default(OPEN)
  messages   Message[]
  createdAt  DateTime @default(now())
}

model Message {
  id             String   @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  direction      Direction   // INBOUND | OUTBOUND
  channel        Channel
  rawPayload     Json
  text           String
  sentiment      String?
  intent         String?
  urgencyScore   Float?
  suggestedReply String?
  createdAt      DateTime @default(now())
}

model MergeSuggestion {
  id            String   @id @default(cuid())
  personAId     String
  personBId     String
  reason        String     // e.g. "phone number mentioned in message matches WhatsApp identity"
  confidence    Float
  status        MergeStatus @default(PENDING) // PENDING | CONFIRMED | DISMISSED
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?     // agent id/name
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  TELEGRAM
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MergeStatus {
  PENDING
  CONFIRMED
  DISMISSED
}
